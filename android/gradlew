##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for maintainability:
#   Common invocation of this script is "./gradlew <task>"
#   The script is designed to be as portable as possible.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=$( expr "$ls" : '.*-> \(.*\)$' )
    if expr "$link" : '/.*' > /dev/null; then
        app_path="$link"
    else
        app_path=$( dirname "$app_path" )/"$link"
    fi
done

APP_HOME=$( dirname "$app_path" )
APP_HOME=$( cd "$APP_HOME" && pwd )

APP_NAME="Gradle"
APP_BASE_NAME=${0##*/}

# Add default JVM options here. You can also use JAVA_OPTS and GRADLE_OPTS to pass JVM options to this script.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Use the maximum available, or at least 512M, for a 64-bit JVM.
if [ "x$JAVA_OPTS" = "x" ]; then
    JAVA_OPTS="-Xmx512m"
fi

# Collect all arguments for the java command, ELIMINATING the first one
# which is the name of the script.
# (This is needed because of the way we call the java command later.)
# (We use a special variable to hold the arguments so that we can
#  handle arguments with spaces in them correctly.)
# (We don't use "$@" because that would include the script name.)
# (We don't use "$*" because that would join all arguments into one string.)
# (We don't use "$1" "$2" ... because we don't know how many there are.)
# (We don't use "shift" because we want to keep the original arguments.)
# (We don't use "set --" because that would overwrite the original arguments.)
# (We don't use "eval" because that's dangerous.)
# (We don't use "printf" because that's not portable.)
# (We don't use "echo" because that's not portable.)

# This is a bit of a hack, but it works.
# It's based on the way the standard Gradle wrapper script does it.
# It's not perfect, but it's better than nothing.

# (The standard Gradle wrapper script is much longer and more complex.)
# (This is a simplified version that should work in most cases.)

warn () {
    echo "$*"
}

die () {
    echo
    echo "$*"
    echo
    exit 1
}

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in
  CYGWIN* )
    cygwin=true
    ;;
  Darwin* )
    darwin=true
    ;;
  MSYS* | MINGW* )
    msys=true
    ;;
  NONSTOP* )
    nonstop=true
    ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar


# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1
    then
        die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
fi

# For Cygwin or MSYS, switch paths to Windows format before running java
if [ "$cygwin" = "true" ] || [ "$msys" = "true" ] ; then
    APP_HOME=$( cygpath --mixed "$APP_HOME" )
    CLASSPATH=$( cygpath --path --mixed "$CLASSPATH" )
    
    JAVACMD=$( cygpath --unix "$JAVACMD" )

    # We build the pattern for arguments to be converted via cygpath
    ROOTDIRSRAW=$( find / -maxdepth 1 -mindepth 1 -type d 2>/dev/null )
    SEP=""
    for dir in $ROOTDIRSRAW ; do
        ROOTDIRS="$ROOTDIRS$SEP$dir"
        SEP="|"
    done
    OURCYGPATTERN="(^($ROOTDIRS))"
    # Add a user-defined pattern to the cygpath arguments
    if [ "$GRADLE_CYGPATTERN" != "" ] ; then
        OURCYGPATTERN="$OURCYGPATTERN|($GRADLE_CYGPATTERN)"
    fi
    # Now convert the arguments - kludge to limit parsing too much it
    for arg in "$@" ; do
        CHECK=$( echo "$arg" | grep -E "$OURCYGPATTERN" - )
        if [ "$CHECK" != "" ] ; then
            arg=$( cygpath --path --ignore --mixed "$arg" )
        fi
        new_args="$new_args \"$arg\""
    done
    eval set -- "$new_args"
fi

# Escape application args
save () {
    for i do printf %s\\n "$i" | sed "s/'/'\\\\''/g;1s/^/'/;\$s/\$/' \\\\/" ; done
    echo " "
}
APP_ARGS=$( save "$@" )

# Collect all arguments for the java command,
# we use eval set -- to properly handle empty arguments and spaces
eval set -- "$DEFAULT_JVM_OPTS $JAVA_OPTS $GRADLE_OPTS \"-Dorg.gradle.appname=$APP_BASE_NAME\" -classpath \"$CLASSPATH\" org.gradle.wrapper.GradleWrapperMain $APP_ARGS"

exec "$JAVACMD" "$@"
